# Optional — copy to .env for local dev (never commit .env)
#
# Online booking URL (Square, Calendly, Vagaro, etc.):
# VITE_BOOKING_URL=https://your-booking-link.example.com
#
# Deposit policy — percentage of service price (scales with each appointment):
# VITE_BOOKING_DEPOSIT_PERCENT=50
# VITE_BOOKING_DEPOSIT_MINIMUM=10
#
# Contact form webhook (Formspree, Netlify, custom endpoint):
# VITE_CONTACT_WEBHOOK_URL=https://formspree.io/f/xxxxx
#
# No env vars are required today — the site builds and runs without them.
# Book buttons link to #book until VITE_BOOKING_URL is set.
